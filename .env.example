# WebDAV configuration
WEBDAV_ROOT_URL=http://localhost:4080
WEBDAV_ROOT_PATH=/webdav

# WebDAV authentication (optional)
WEBDAV_AUTH_ENABLED=true
WEBDAV_USERNAME=admin

# WebDAV password must be plain text (required when auth enabled)
WEBDAV_PASSWORD=password

# Server configuration (for HTTP mode)
SERVER_PORT=3000

# Public URL of this server, used as the OAuth issuer/resource URL.
# On Railway this defaults to RAILWAY_PUBLIC_DOMAIN if unset.
# PUBLIC_URL=https://your-server.example.com

# OAuth 2.1 login credentials for /mcp (single-user).
# These are the credentials entered in the browser login form during the
# OAuth authorization flow, not WebDAV credentials.
AUTH_ENABLED=true
AUTH_USERNAME=user
AUTH_PASSWORD=pass

# Auth password can be a bcrypt hash instead of plain text
# AUTH_PASSWORD={bcrypt}$2y$05$CyLKnUwn9fqqKQFEbxpZFuE9mzWR/x8t6TE7.CgAN0oT8I/5jKJBy

# Console log verbosity: error | warning | info (default) | debug.
# debug also logs every MCP tool call's name, arguments, and result.
# LOG_LEVEL=debug

# Anna's Archive tools (book_search, book_download, article_search, article_download).
# Search works without any of these set. Downloads require ANNAS_SECRET_KEY
# (from a donation to Anna's Archive, https://annas-archive.gl/donate) and save
# the file to the WebDAV server at a path you specify per call.
# ANNAS_SECRET_KEY=your-annas-archive-api-key
# ANNAS_BASE_URL=annas-archive.gl

# Without a membership key, set ANNAS_SECRET_KEY=slow instead: downloads then
# return /slow_download/ links for the user to open in a browser, rather than
# fetching the file server-side (that page requires solving a browser
# challenge that a plain HTTP request can't pass).
# ANNAS_SECRET_KEY=slow
